rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny. Every read/write below must explicitly satisfy owner-only.
    match /{document=**} {
      allow read, write: if false;
    }

    // Per-user subtree. Anonymous and linked Firebase Auth users alike use
    // their UID as the partition key. A signed-in user can read/write only
    // their own subtree.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
