# Functions secrets — never commit real values. For local development copy
# this to .env (gitignored). For production use Firebase Secret Manager:
#
#   firebase functions:secrets:set SENDGRID_API_KEY
#
# The SendGrid template ID and sender are non-secret config; we still expose
# them as secrets here so all configuration lives in one place.

SENDGRID_API_KEY=
SENDGRID_TEMPLATE_ID=
SENDGRID_SENDER=
